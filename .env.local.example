# =================================================================
# Chirality Framework Environment Configuration
# =================================================================
# Copy this file to .env.local and fill in your values
# Note: Also needed in .env for Python CLI tools
# =================================================================

# -----------------------------------------------------------------
# Neo4j Database Configuration (REQUIRED)
# -----------------------------------------------------------------
# CRITICAL: Use NEO4J_USER not NEO4J_USERNAME
NEO4J_URI=neo4j+s://your-instance.databases.neo4j.io
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-aura-password
NEO4J_DATABASE=neo4j

# Optional: Neo4j Aura Instance Details
AURA_INSTANCEID=your-instance-id
AURA_INSTANCENAME=chirality-framework

# -----------------------------------------------------------------
# OpenAI Configuration (REQUIRED for semantic operations)
# -----------------------------------------------------------------
OPENAI_API_KEY=sk-proj-your-api-key-here

# Optional: OpenAI Settings
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

# -----------------------------------------------------------------
# GraphQL Service Configuration
# -----------------------------------------------------------------
NEXT_PUBLIC_GRAPH_API=http://localhost:8080/graphql
GRAPH_API_SCHEMA=http://localhost:8080/graphql
GRAPHQL_PORT=8080

# Feature flags
NEXT_PUBLIC_USE_GRAPHQL=true
ENABLE_GRAPHQL_PLAYGROUND=true

# -----------------------------------------------------------------
# Application Settings
# -----------------------------------------------------------------
# Base URLs
NEXT_PUBLIC_API_BASE=http://localhost:3000
NEXT_PUBLIC_LEGACY_API=http://localhost:3000

# -----------------------------------------------------------------
# CF14 v2.1.1 Features (Optional)
# -----------------------------------------------------------------
CF14_VERSION=2.1.1
CF14_ENABLE_ARRAY_PH=true
CF14_LEGACY_API_SUPPORT=true
CF14_DOMAIN_PACKS_ENABLED=true

# -----------------------------------------------------------------
# Development Settings
# -----------------------------------------------------------------
NODE_ENV=development
DEBUG=false
LOG_LEVEL=info

# -----------------------------------------------------------------
# Python CLI Configuration
# -----------------------------------------------------------------
# Used by chirality_cli.py and neo4j_admin.py
PYTHON_ENV=development
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_TTL=3600

# -----------------------------------------------------------------
# Security (Production only)
# -----------------------------------------------------------------
# JWT configuration (if using authentication)
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=7d

# CORS settings
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# -----------------------------------------------------------------
# Notes:
# -----------------------------------------------------------------
# 1. Copy to both .env.local (for Next.js) and .env (for Python)
# 2. Never commit with real credentials
# 3. The GraphQL service has its own .env in graphql-service/
# 4. For production, use environment variables from your platform
# -----------------------------------------------------------------